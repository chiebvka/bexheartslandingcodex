7:["$","main",null,{"className":"article-page","children":[["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"BlogPosting\",\"headline\":\"How to Start Praying Together as a Couple Without Making It Awkward\",\"description\":\"A practical, gentle way for Christian couples to make prayer feel normal, honest, and sustainable.\",\"datePublished\":\"2026-07-10\",\"mainEntityOfPage\":\"https://bexhearts.com/blog/how-to-start-praying-together-as-a-couple\",\"author\":{\"@type\":\"Organization\",\"name\":\"Bexhearts\",\"url\":\"https://bexhearts.com\"},\"publisher\":{\"@type\":\"Organization\",\"name\":\"Bexhearts\",\"url\":\"https://bexhearts.com\"}}"}}],["$","article",null,{"className":"article-shell","children":[["$","$L12",null,{"href":"/blog","className":"back-link","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-arrow-left","aria-hidden":"true","children":[["$","path","1l729n",{"d":"m12 19-7-7 7-7"}],["$","path","x3x0zl",{"d":"M19 12H5"}],"$undefined"]}],"Blog"]}],["$","header",null,{"className":"article-hero","children":[["$","p",null,{"className":"section-kicker","children":"Prayer"}],["$","h1",null,{"children":"How to Start Praying Together as a Couple Without Making It Awkward"}],["$","p",null,{"children":"A practical, gentle way for Christian couples to make prayer feel normal, honest, and sustainable."}],["$","div",null,{"className":"article-meta","children":[["$","time",null,{"dateTime":"2026-07-10","children":"2026-07-10"}],["$","span",null,{"children":[4," min read"]}]]}]]}],["$","div",null,{"className":"article-content","children":[["$","section","0",{"children":["$undefined",[["$","p","A lot of couples want prayer to be part of their relationship, but they wait until it feels natural. The better move is to make it small enough to repeat.",{"children":"A lot of couples want prayer to be part of their relationship, but they wait until it feels natural. The better move is to make it small enough to repeat."}],["$","p","Start with sixty seconds. Thank God for one specific thing. Ask for help with one real thing. End before it becomes a performance.",{"children":"Start with sixty seconds. Thank God for one specific thing. Ask for help with one real thing. End before it becomes a performance."}]]]}],["$","section","Use a simple three-part rhythm",{"children":[["$","h2",null,{"children":"Use a simple three-part rhythm"}],[["$","p","Try gratitude, request, and blessing. One of you names something you are thankful for, one of you names something you need help with, and then you pray a short blessing over the other person.",{"children":"Try gratitude, request, and blessing. One of you names something you are thankful for, one of you names something you need help with, and then you pray a short blessing over the other person."}],["$","p","The goal is not impressive language. The goal is shared attention before God.",{"children":"The goal is not impressive language. The goal is shared attention before God."}]]]}],["$","section","Let the habit stay ordinary",{"children":[["$","h2",null,{"children":"Let the habit stay ordinary"}],[["$","p","Prayer together does not need candles, a perfect mood, or a long devotional setup every night. It can happen before a drive, after dinner, or right before sleep.",{"children":"Prayer together does not need candles, a perfect mood, or a long devotional setup every night. It can happen before a drive, after dinner, or right before sleep."}],["$","p","Bexhearts gives couples a practical place for that kind of faithfulness: a daily devotional, shared prayer, honest check-ins, and small actions they can repeat.",{"children":"Bexhearts gives couples a practical place for that kind of faithfulness: a daily devotional, shared prayer, honest check-ins, and small actions they can repeat."}]]]}]]}],"$L13","$L14"]}]]}]
