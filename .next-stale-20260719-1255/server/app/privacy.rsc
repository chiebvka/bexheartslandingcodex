e-hero","children":[["$","p",null,{"className":"section-kicker","children":"Draft for attorney review"}],["$","h1",null,{"children":"Privacy Policy"}],["$","p",null,{"children":["Effective date: to be set at launch. Contact:"," ",["$","a",null,{"href":"mailto:support@bexhearts.com","children":"support@bexhearts.com"}],"."]}]]}],["$","div",null,{"className":"article-content","children":[["$","section",null,{"children":[["$","h2",null,{"children":"1. What Bexhearts is"}],["$","p",null,{"children":"Bexhearts is a mobile app for Christian couples: shared devotionals, prayers, check-ins, boundaries, dates, a couple journal, and progress features. Because of the app’s nature, some of what you share is religious in nature — sensitive personal data in many jurisdictions (for example under GDPR Article 9). We treat everything in this policy with that in mind."}]]}],"$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10"]}]]}]}],null,"$L11"]}],{},null,false]},null,false]},null,false],"$L12",false]],"m":"$undefined","G":["$13",[]],"s":false,"S":true}
